# ── Copy this to .env and fill in real values ──────────────────────────────
# NEVER commit .env to git

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=OSPWNSK29373947WNOZNWSKKWKWOSKWKSOSKENSNSJEJNS283J8JAJWIW28228288282IIWJSJJKZSKJssnsnsn82827383nsjsnzihdhrekwksehdsj292838

# Database
DATABASE_URL=sqlite:///dreem_sms.db
# For PostgreSQL: postgresql://user:password@localhost:5432/dreem_sms

# CORS: comma-separated list of allowed origins (empty = no CORS)
CORS_ORIGINS=

# Webhook secret (must be sent by your SMS gateway as X-Webhook-Secret header)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=DREEMSMSPANELPROVIDEOTP

# Set to 'true' to allow public self-registration (default: false)
REGISTRATION_ENABLED=false

# Max destinations per bulk SMS request (default: 500)
BULK_SMS_MAX_DESTINATIONS=500

# Server settings
HOST=0.0.0.0
PORT=10075
FLASK_ENV=development
FLASK_DEBUG=false
